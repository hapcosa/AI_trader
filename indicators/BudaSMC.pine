// ─── NEW UDTs: MTF & SIGNALS ───────────────────────────────────────────────

// MTF state holder / Estado del timeframe superior
type MTFState
    int   trend      // 1 = bullish, -1 = bearish, 0 = neutral
    float bosLevel   // Current BOS level in HTF
    float chochLevel // Current CHoCH level in HTF
    bool  hasBullOB  // Active bullish OB in HTF
    bool  hasBearOB  // Active bearish OB in HTF
    bool  hasBullFVG // Active bullish FVG in HTF
    bool  hasBearFVG // Active bearish FVG in HTF

// Trade signal / Señal de trading
type TradeSignal
    bool  isLong       // true = LONG, false = SHORT
    string signalType  // "A", "B", "C"
    float entry        // Suggested entry price
    float stopLoss     // Stop loss level
    float takeProfit   // Take profit level
    int   barIdx       // Bar index of signal
    int   confluence   // Number of confluent factors (1-5)
    string reason      // Description of signal

